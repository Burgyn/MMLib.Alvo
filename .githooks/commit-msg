#!/usr/bin/env bash
# commit-msg: enforce Conventional Commits on the subject line, so the release
# changelog can be generated from history (#14). Merge/revert/fixup subjects
# are exempt. Requires the one-time: git config core.hooksPath .githooks
set -euo pipefail
subject="$(head -1 "$1")"

if echo "$subject" | grep -qE '^(Merge |Revert |fixup!|squash!)'; then
  exit 0
fi

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([^)]+\))?!?: .+'
if ! echo "$subject" | grep -qE "$pattern"; then
  echo "commit-msg: subject must follow Conventional Commits." >&2
  echo "  <type>[(scope)][!]: <description>" >&2
  echo "  types: feat fix docs style refactor perf test build ci chore revert" >&2
  echo "  got: $subject" >&2
  exit 1
fi
