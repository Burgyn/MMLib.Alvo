{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alvo.dev/schema/v1/project.json",
  "title": "Alvo Project Descriptor",
  "description": "Declarative definition of an Alvo backend. One artifact for every path: Docker mount, `alvo apply`, Management API, AddAlvo().FromDescriptor(), and admin UI export. Conditions (rules, hook/automation conditions) use a CEL subset; payload transformations use JSONata. Env/secrets (connection strings, admin credentials) do NOT belong here — the descriptor defines the backend, not the infrastructure configuration.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "entities"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,62}$",
      "description": "Project identifier (kebab-case). In standalone mode it identifies the project within the instance."
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Project schema version. Incremented on every applied change; used for optimistic concurrency checks during apply."
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "description": "Authentication and application roles.",
      "properties": {
        "providers": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "local",
              "google",
              "microsoft",
              "github",
              "apple",
              "oidc"
            ]
          },
          "description": "Enabled identity providers. `local` = ASP.NET Core Identity; `oidc` = generic OIDC relying party (endpoint configuration is infra/env)."
        },
        "roles": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          },
          "description": "Application roles beyond the built-in ones (anon, authenticated, admin). Referenced in CEL via @user.role."
        }
      }
    },
    "admin": {
      "type": "object",
      "additionalProperties": false,
      "description": "Admin dashboard configuration — definition ONLY (access mapping, branding). Enablement, path, IP allowlist and the script UI-edit gate are env.",
      "properties": {
        "access": {
          "type": "object",
          "additionalProperties": false,
          "description": "Mapping to dashboard access levels via CEL expressions over @user.",
          "properties": {
            "admin": {
              "$ref": "#/$defs/cel"
            },
            "developer": {
              "$ref": "#/$defs/cel"
            },
            "viewer": {
              "$ref": "#/$defs/cel"
            }
          }
        },
        "branding": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "title": {
              "type": "string",
              "maxLength": 60
            },
            "logoUrl": {
              "type": "string",
              "format": "uri-reference"
            }
          }
        }
      }
    },
    "entities": {
      "type": "object",
      "description": "Entity definitions. Key = entity name (snake_case, plural recommended). Each entity auto-generates a CRUD API, validation, and a schema registry record.",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_]{0,62}$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/entity"
      }
    },
    "automation": {
      "type": "array",
      "description": "ECA rules (event–condition–action). Run post-commit from the outbox, durable, with retries.",
      "items": {
        "$ref": "#/$defs/automationRule"
      }
    },
    "webhooks": {
      "type": "object",
      "additionalProperties": false,
      "description": "Managed webhook endpoints (Standard Webhooks: HMAC signing, retries, DLQ).",
      "properties": {
        "endpoints": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[a-z][a-z0-9-]{0,62}$"
          },
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "url",
              "secretRef"
            ],
            "properties": {
              "url": {
                "type": "string",
                "format": "uri",
                "description": "HTTPS target."
              },
              "secretRef": {
                "type": "string",
                "description": "Secret name in ISecretStore (never the secret value itself)."
              },
              "description": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "functions": {
      "type": "object",
      "description": "Custom logic — csx scripts (standalone). Key = function name. Trust: admin-level code.",
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9-]{0,62}$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "script"
        ],
        "properties": {
          "script": {
            "type": "string",
            "description": "Relative path to a .csx file inside the descriptor bundle.",
            "pattern": "\\.csx$"
          },
          "trigger": {
            "description": "Optional trigger; a function without a trigger is only invocable from the `function` automation action.",
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "http"
                ],
                "properties": {
                  "http": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "route"
                    ],
                    "properties": {
                      "route": {
                        "type": "string",
                        "pattern": "^/"
                      },
                      "method": {
                        "enum": [
                          "GET",
                          "POST",
                          "PUT",
                          "PATCH",
                          "DELETE"
                        ]
                      }
                    }
                  }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "schedule"
                ],
                "properties": {
                  "schedule": {
                    "$ref": "#/$defs/cron"
                  }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "event"
                ],
                "properties": {
                  "event": {
                    "$ref": "#/$defs/eventPattern"
                  }
                }
              }
            ]
          },
          "execution": {
            "enum": [
              "sync",
              "queued"
            ],
            "default": "queued",
            "description": "Sync = in the request path (short timeout); queued = via outbox and worker (default)."
          }
        }
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{0,62}$"
    },
    "cel": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "Condition in the CEL subset. Context: @user, @tenant; hooks/events additionally expose old, new, changed(field). Compiled fail-fast at apply time."
    },
    "jsonata": {
      "type": "string",
      "minLength": 1,
      "maxLength": 8000,
      "description": "JSONata transformation expression (JSON → JSON). Runs strictly post-commit (after-side), with depth/time limits. {{...}} templates are syntactic sugar."
    },
    "cron": {
      "type": "string",
      "pattern": "^\\S+ \\S+ \\S+ \\S+ \\S+$",
      "description": "Cron expression (5 fields, UTC)."
    },
    "eventPattern": {
      "type": "string",
      "pattern": "^(entity|auth|storage)\\.[a-z0-9_*]+\\.[a-z]+$",
      "description": "Event pattern, e.g. entity.deals.updated or entity.*.created."
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fields"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "fields": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "pattern": "^[a-z][a-z0-9_]{0,62}$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/field"
          },
          "description": "Entity fields. The `id` field (uuid, PK) is added automatically when not defined."
        },
        "rules": {
          "type": "object",
          "additionalProperties": false,
          "description": "Per-operation authorization rules — CEL, compiled into a SQL predicate. Missing operation = deny (secure-by-default).",
          "properties": {
            "list": {
              "$ref": "#/$defs/cel"
            },
            "get": {
              "$ref": "#/$defs/cel"
            },
            "create": {
              "$ref": "#/$defs/cel"
            },
            "update": {
              "$ref": "#/$defs/cel"
            },
            "delete": {
              "$ref": "#/$defs/cel"
            }
          }
        },
        "hooks": {
          "type": "object",
          "additionalProperties": false,
          "description": "Lifecycle hooks. before* = in-transaction, no network, may reject/mutate; after* = post-commit from the outbox.",
          "properties": {
            "beforeCreate": {
              "$ref": "#/$defs/beforeHookList"
            },
            "beforeUpdate": {
              "$ref": "#/$defs/beforeHookList"
            },
            "beforeDelete": {
              "$ref": "#/$defs/beforeHookList"
            },
            "afterCreate": {
              "$ref": "#/$defs/afterHookList"
            },
            "afterUpdate": {
              "$ref": "#/$defs/afterHookList"
            },
            "afterDelete": {
              "$ref": "#/$defs/afterHookList"
            }
          }
        },
        "realtime": {
          "type": "boolean",
          "default": true,
          "description": "Publish changes over the realtime channel (with subject-level authz)."
        },
        "indexes": {
          "type": "array",
          "description": "Explicit composite/extra indexes beyond the automatic ones (PK, unique, ref).",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "fields"
            ],
            "properties": {
              "fields": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "$ref": "#/$defs/identifier"
                }
              },
              "unique": {
                "type": "boolean",
                "default": false
              }
            }
          }
        }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "string",
            "text",
            "integer",
            "decimal",
            "boolean",
            "date",
            "datetime",
            "uuid",
            "json",
            "enum",
            "ref"
          ]
        },
        "description": {
          "type": "string"
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "unique": {
          "type": "boolean",
          "default": false
        },
        "nullable": {
          "type": "boolean",
          "description": "Explicitly allow NULL; the default is derived from required."
        },
        "default": {
          "description": "Default value (must match the field type) or a function: now(), gen_random_uuid()."
        },
        "maxLength": {
          "type": "integer",
          "minimum": 1,
          "description": "type=string only."
        },
        "precision": {
          "type": "integer",
          "minimum": 1,
          "maximum": 38,
          "description": "type=decimal only."
        },
        "scale": {
          "type": "integer",
          "minimum": 0,
          "description": "type=decimal only."
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          },
          "description": "type=enum only."
        },
        "entity": {
          "$ref": "#/$defs/identifier",
          "description": "type=ref only — target entity (FK to its id)."
        },
        "onDelete": {
          "enum": [
            "restrict",
            "cascade",
            "setNull"
          ],
          "default": "restrict",
          "description": "type=ref only."
        },
        "format": {
          "enum": [
            "email",
            "uri",
            "phone"
          ],
          "description": "type=string only — validation format."
        },
        "validation": {
          "$ref": "#/$defs/cel",
          "description": "Optional CEL value validation (context: value, new)."
        },
        "index": {
          "type": "boolean",
          "default": false,
          "description": "Create an index (for dynamic entities = generated column + index over the JSON path)."
        },
        "hidden": {
          "type": "boolean",
          "default": false,
          "description": "Field is never returned in API responses (e.g. internal flags)."
        },
        "readOnly": {
          "type": "boolean",
          "default": false,
          "description": "Field cannot be modified via the API (hooks/system only)."
        },
        "computed": {
          "$ref": "#/$defs/cel",
          "description": "Value derived from other fields of the SAME row (pure arithmetic/expression, deterministic, no side effects), e.g. unit_price * amount. Maps to a DB stored generated column. Field becomes read-only."
        },
        "rollup": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "from",
            "op",
            "field"
          ],
          "description": "Value aggregated over RELATED records, transactionally consistent (e.g. sum of child line_total). Framework maintains it; the field is read-only.",
          "properties": {
            "from": {
              "$ref": "#/$defs/identifier",
              "description": "Child entity that references this one."
            },
            "op": {
              "enum": [
                "sum",
                "count",
                "avg",
                "min",
                "max"
              ]
            },
            "field": {
              "$ref": "#/$defs/identifier",
              "description": "Field on the child entity to aggregate (omit-able for count)."
            },
            "where": {
              "$ref": "#/$defs/cel",
              "description": "Optional CEL filter on child records."
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "enum"
              }
            }
          },
          "then": {
            "required": [
              "values"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "ref"
              }
            }
          },
          "then": {
            "required": [
              "entity"
            ]
          }
        },
        {
          "if": {
            "not": {
              "properties": {
                "type": {
                  "const": "enum"
                }
              }
            }
          },
          "then": {
            "properties": {
              "values": false
            }
          }
        },
        {
          "if": {
            "not": {
              "properties": {
                "type": {
                  "const": "ref"
                }
              }
            }
          },
          "then": {
            "properties": {
              "entity": false,
              "onDelete": false
            }
          }
        },
        {
          "if": {
            "not": {
              "properties": {
                "type": {
                  "const": "string"
                }
              }
            }
          },
          "then": {
            "properties": {
              "maxLength": false,
              "format": false
            }
          }
        },
        {
          "if": {
            "not": {
              "properties": {
                "type": {
                  "const": "decimal"
                }
              }
            }
          },
          "then": {
            "properties": {
              "precision": false,
              "scale": false
            }
          }
        },
        {
          "if": {
            "required": [
              "computed"
            ]
          },
          "then": {
            "properties": {
              "rollup": false,
              "default": false
            }
          }
        },
        {
          "if": {
            "required": [
              "rollup"
            ]
          },
          "then": {
            "properties": {
              "computed": false,
              "default": false
            }
          }
        }
      ]
    },
    "beforeHookList": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "action"
        ],
        "properties": {
          "condition": {
            "$ref": "#/$defs/cel"
          },
          "action": {
            "description": "Before-actions run in-transaction: reject or mutate only. No network, no external calls.",
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "reject"
                ],
                "properties": {
                  "reject": {
                    "type": "string",
                    "maxLength": 500,
                    "description": "Cancels the operation; the text becomes the detail of the RFC 7807 error."
                  }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "mutate"
                ],
                "properties": {
                  "mutate": {
                    "type": "object",
                    "minProperties": 1,
                    "description": "Payload patch before write: field → value or CEL expression."
                  }
                }
              }
            ]
          }
        }
      }
    },
    "afterHookList": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "action"
        ],
        "properties": {
          "condition": {
            "$ref": "#/$defs/cel"
          },
          "action": {
            "$ref": "#/$defs/action"
          }
        }
      }
    },
    "automationRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "trigger",
        "actions"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "description": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "trigger": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "event"
              ],
              "properties": {
                "event": {
                  "$ref": "#/$defs/eventPattern"
                }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "schedule"
              ],
              "properties": {
                "schedule": {
                  "$ref": "#/$defs/cron"
                }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "inboundWebhook"
              ],
              "properties": {
                "inboundWebhook": {
                  "$ref": "#/$defs/identifier",
                  "description": "Inbound endpoint name; receiving a request triggers the rule."
                }
              }
            }
          ]
        },
        "condition": {
          "$ref": "#/$defs/cel"
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/action"
          }
        }
      }
    },
    "action": {
      "description": "After-side action (post-commit, durable, retries). Payload transformations = JSONata.",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "endpoint"
          ],
          "properties": {
            "type": {
              "const": "webhook"
            },
            "endpoint": {
              "$ref": "#/$defs/identifier"
            },
            "payload": {
              "$ref": "#/$defs/jsonata"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "template",
            "to"
          ],
          "properties": {
            "type": {
              "const": "email"
            },
            "template": {
              "$ref": "#/$defs/identifier"
            },
            "to": {
              "type": "string",
              "description": "Address or a {{...}} template."
            },
            "data": {
              "$ref": "#/$defs/jsonata"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "name"
          ],
          "properties": {
            "type": {
              "const": "function"
            },
            "name": {
              "$ref": "#/$defs/identifier"
            },
            "input": {
              "$ref": "#/$defs/jsonata"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "entity",
            "payload"
          ],
          "properties": {
            "type": {
              "const": "entity.update"
            },
            "entity": {
              "$ref": "#/$defs/identifier"
            },
            "recordId": {
              "type": "string",
              "description": "Id or {{...}}; omit to create."
            },
            "payload": {
              "type": "object",
              "minProperties": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "url"
          ],
          "properties": {
            "type": {
              "const": "http.call"
            },
            "url": {
              "type": "string",
              "format": "uri"
            },
            "method": {
              "enum": [
                "GET",
                "POST",
                "PUT",
                "PATCH",
                "DELETE"
              ],
              "default": "POST"
            },
            "headersSecretRef": {
              "type": "string"
            },
            "payload": {
              "$ref": "#/$defs/jsonata"
            }
          }
        }
      ]
    }
  }
}
