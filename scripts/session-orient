#!/usr/bin/env bash
# SessionStart hook output — a few lines of orientation injected into context at
# session start, so an agent begins pointed at the current phase and knows the
# brief's freshness instead of hoping it reads docs/PLAN.md first. Keep it tiny:
# this text is paid on every session start.
set -euo pipefail
cd "$(git rev-parse --show-toplevel 2>/dev/null || echo .)"

echo "Alvo orientation:"

if [ -f docs/PLAN.md ]; then
  # The checklist marker line (starts with the ← arrow) plus the phase line
  # above it. Anchoring on a leading ← avoids the prose mentions of the marker.
  grep -m1 -B1 '^[[:space:]]*←' docs/PLAN.md | sed 's/^/  /' || echo "  (no ← YOU ARE HERE marker found in docs/PLAN.md)"
else
  echo "  (docs/PLAN.md not found)"
fi

if [ -x scripts/check-brief-freshness ]; then
  if scripts/check-brief-freshness >/dev/null 2>&1; then
    echo "  design-brief.en.md: fresh."
  else
    echo "  design-brief.en.md: STALE vs its sources — regenerate via the alvo-regen-brief skill."
  fi
fi

echo "  Map: docs/PLAN.md · whole context: docs/design-brief.en.md · before a PR: dispatch alvo-plan-guard."
